# OpenClaw Command Center environment
# Copy to .env.local for local development. Production values should be injected by the host.

# Public app label shown in header/browser title
VITE_APP_NAME=OpenClaw Command Center

# Gateway/API base URL. Leave blank when served inside OpenClaw and using local-only fallback state.
# Examples: http://127.0.0.1:18789, https://your-gateway.example.com
VITE_API_BASE_URL=
VITE_API_TIMEOUT_MS=10000

# Auth mode: demo | firebase | openclaw
# - demo: local preview only; no external auth
# - firebase: standalone Firebase auth
# - openclaw: trust OpenClaw Control UI/device auth
VITE_AUTH_MODE=openclaw

# Legacy local-preview switch. Prefer VITE_AUTH_MODE=demo.
VITE_ALLOW_DEMO_AUTH=false

# Firebase auth values; required only when VITE_AUTH_MODE=firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
